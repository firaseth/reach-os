# ─────────────────────────────────────────────────────────────
# Reach OS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to source control.
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# Path to your SQLite file (or PostgreSQL URL for production)
DATABASE_URL="file:./prisma/dev.db"

# ── Authentication ───────────────────────────────────────────
# A long random secret used to sign JWT tokens.
# Generate one with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-secret"

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── AI (optional) ────────────────────────────────────────────
# API key for any AI integrations (pitch-deck assistant, etc.)
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
